<Window x:Class="SystemChecker.TelemetryMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SystemChecker.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="System Checker" Width="1360" Height="860" MinWidth="1100" MinHeight="720"
        WindowStartupLocation="CenterScreen" WindowStyle="None" Background="#F5F6F8"
        FontFamily="Segoe UI" Foreground="#181B20" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" CornerRadius="8" GlassFrameThickness="0" ResizeBorderThickness="6" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <SolidColorBrush x:Key="Canvas" Color="#F5F6F8"/><SolidColorBrush x:Key="Panel" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Ink" Color="#181B20"/><SolidColorBrush x:Key="Muted" Color="#68707D"/>
        <SolidColorBrush x:Key="Line" Color="#DEE2E8"/><SolidColorBrush x:Key="Accent" Color="#1687C8"/>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/><Setter Property="BorderBrush" Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="5"/><Setter Property="Padding" Value="18"/>
        </Style>
        <Style x:Key="Nav" TargetType="Button">
            <Setter Property="Height" Value="46"/><Setter Property="Margin" Value="0"/><Setter Property="Padding" Value="20,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/><Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9099A7"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Grid><Border x:Name="ActiveLine" Width="3" Background="Transparent" HorizontalAlignment="Left"/><Border x:Name="Hover" Background="{TemplateBinding Background}"><ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/></Border></Grid><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Hover" Property="Background" Value="#171D25"/><Setter Property="Foreground" Value="White"/></Trigger><Trigger Property="Tag" Value="Active"><Setter TargetName="ActiveLine" Property="Background" Value="#28A7E8"/><Setter TargetName="Hover" Property="Background" Value="#171D25"/><Setter Property="Foreground" Value="White"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="TextButton" TargetType="Button">
            <Setter Property="Padding" Value="16,9"/><Setter Property="Background" Value="#181B20"/><Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="4"><ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center"/></Border></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="WindowButton" TargetType="Button">
            <Setter Property="Width" Value="42"/><Setter Property="Height" Value="38"/><Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6A7280"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/><Setter Property="Background" Value="#E8EBEF"/><Setter Property="Foreground" Value="{StaticResource Accent}"/><Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/><Setter Property="Foreground" Value="{StaticResource Ink}"/><Setter Property="BorderBrush" Value="{StaticResource Line}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="GridLinesVisibility" Value="Horizontal"/><Setter Property="HorizontalGridLinesBrush" Value="#E8EBEF"/><Setter Property="RowBackground" Value="White"/><Setter Property="AlternatingRowBackground" Value="#FAFBFC"/><Setter Property="HeadersVisibility" Value="Column"/><Setter Property="RowHeight" Value="48"/>
        </Style>
        <Style TargetType="DataGridColumnHeader"><Setter Property="Background" Value="#F2F4F6"/><Setter Property="Foreground" Value="#525A66"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Height" Value="44"/><Setter Property="Padding" Value="16,0"/><Setter Property="BorderBrush" Value="{StaticResource Line}"/><Setter Property="BorderThickness" Value="0,0,0,1"/><Setter Property="VerticalContentAlignment" Value="Center"/></Style>
        <Style TargetType="DataGridCell"><Setter Property="Foreground" Value="{StaticResource Ink}"/><Setter Property="Padding" Value="16,0"/><Setter Property="BorderThickness" Value="0"/><Setter Property="VerticalContentAlignment" Value="Center"/></Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition x:Name="SidebarColumn" Width="226"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#0E1117">
            <Grid><Grid.RowDefinitions><RowDefinition Height="68"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Grid Margin="20,0"><Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition/></Grid.ColumnDefinitions><Border Width="28" Height="28" Background="#1687C8" CornerRadius="4" VerticalAlignment="Center"><TextBlock Text="SC" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center"><TextBlock Text="SYSTEM CHECKER" Foreground="#F4F6F8" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="LOCAL TELEMETRY" Foreground="#596372" FontSize="8" Margin="0,2,0,0"/></StackPanel></Grid>
                <StackPanel Grid.Row="1" Margin="0,16,0,0">
                    <Button x:Name="OverviewNav" Style="{StaticResource Nav}" Tag="Active" CommandParameter="Overview" Click="Navigate_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="01" FontFamily="Consolas" FontSize="10" Width="28"/><TextBlock Text="OVERVIEW" FontSize="11" FontWeight="SemiBold"/></StackPanel></Button>
                    <Button x:Name="HardwareNav" Style="{StaticResource Nav}" CommandParameter="Hardware" Click="Navigate_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="02" FontFamily="Consolas" FontSize="10" Width="28"/><TextBlock Text="HARDWARE" FontSize="11" FontWeight="SemiBold"/></StackPanel></Button>
                    <Button x:Name="BenchmarkNav" Style="{StaticResource Nav}" CommandParameter="Benchmark" Click="Navigate_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="03" FontFamily="Consolas" FontSize="10" Width="28"/><TextBlock Text="BENCHMARK" FontSize="11" FontWeight="SemiBold"/></StackPanel></Button>
                    <Button x:Name="ReportNav" Style="{StaticResource Nav}" CommandParameter="Report" Click="Navigate_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="04" FontFamily="Consolas" FontSize="10" Width="28"/><TextBlock Text="REPORT" FontSize="11" FontWeight="SemiBold"/></StackPanel></Button>
                </StackPanel>
                <StackPanel Grid.Row="2" Margin="20,0,20,20"><Separator Background="#252B34"/><TextBlock Text="WINDOWS · X64" Foreground="#596372" FontFamily="Consolas" FontSize="9" Margin="0,13,0,0"/></StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="{StaticResource Canvas}">
            <Grid.RowDefinitions><RowDefinition Height="58"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="12,0,8,0"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <Button x:Name="SidebarToggle" Content="☰" Width="42" Height="38" Background="Transparent" BorderThickness="0" Foreground="#525A66" FontSize="16" Click="ToggleSidebar_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0"><TextBlock x:Name="PageTitle" Text="OVERVIEW" FontSize="12" FontWeight="SemiBold"/><TextBlock Text=" / LOCAL SYSTEM" Foreground="#9AA1AC" FontSize="11"/></StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True"><StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0"><Ellipse Width="7" Height="7" Fill="#24A467" Margin="0,0,7,0"/><TextBlock Text="{Binding StatusText}" Foreground="#5F6874" FontSize="10"/></StackPanel><Button x:Name="UpdateBadgeButton" Visibility="Collapsed" Height="30" MinHeight="30" Padding="12,0" Margin="0,0,8,0" VerticalAlignment="Center" Background="#EAF3FC" Foreground="#235F97" BorderBrush="#C8DDF0" FontSize="10" FontWeight="SemiBold" Content="업데이트" Click="UpdateBadge_Click"/><Button Style="{StaticResource WindowButton}" Content="—" Click="Minimize_Click"/><Button Style="{StaticResource WindowButton}" Content="□" Click="Maximize_Click"/><Button Style="{StaticResource WindowButton}" Content="×" Click="Close_Click"/></StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="22,18,16,16">
                <ScrollViewer x:Name="OverviewPage" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <Border Style="{StaticResource PanelStyle}" Margin="0,0,8,0"><StackPanel><TextBlock Text="CPU LOAD" Foreground="{StaticResource Muted}" FontSize="10" FontWeight="SemiBold"/><TextBlock Text="{Binding CpuValue}" FontSize="26" FontWeight="SemiBold" Margin="0,8,0,4"/><TextBlock Text="{Binding CpuDetail}" Foreground="{StaticResource Muted}" FontSize="10"/></StackPanel></Border>
                            <Border Grid.Column="1" Style="{StaticResource PanelStyle}" Margin="0,0,8,0"><StackPanel><TextBlock Text="MEMORY" Foreground="{StaticResource Muted}" FontSize="10" FontWeight="SemiBold"/><TextBlock Text="{Binding MemoryValue}" FontSize="20" FontWeight="SemiBold" Margin="0,11,0,5"/><TextBlock Text="{Binding MemoryDetail}" Foreground="{StaticResource Muted}" FontSize="10"/></StackPanel></Border>
                            <Border Grid.Column="2" Style="{StaticResource PanelStyle}" Margin="0,0,8,0"><StackPanel><TextBlock Text="DISK I/O" Foreground="{StaticResource Muted}" FontSize="10" FontWeight="SemiBold"/><TextBlock Text="{Binding DiskValue}" FontSize="24" FontWeight="SemiBold" Margin="0,9,0,4"/><TextBlock Text="{Binding DiskDetail}" Foreground="{StaticResource Muted}" FontSize="10" TextTrimming="CharacterEllipsis"/></StackPanel></Border>
                            <Border Grid.Column="3" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Text="NETWORK" Foreground="{StaticResource Muted}" FontSize="10" FontWeight="SemiBold"/><TextBlock Text="{Binding NetworkValue}" FontSize="24" FontWeight="SemiBold" Margin="0,9,0,4"/><TextBlock Text="{Binding NetworkDetail}" Foreground="{StaticResource Muted}" FontSize="10"/></StackPanel></Border>
                        </Grid>
                        <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                            <Border Style="{StaticResource PanelStyle}" Margin="0,0,8,8"><StackPanel><Grid Margin="0,0,0,8"><TextBlock Text="CPU · 60 SEC" FontSize="11" FontWeight="SemiBold"/><TextBlock Text="{Binding CpuValue}" HorizontalAlignment="Right" Foreground="#1687C8" FontFamily="Consolas"/></Grid><controls:SmoothRealtimeChart Values="{Binding CpuHistory}" Stroke="#1687C8" Minimum="0" Maximum="100" Unit="%" Height="170"/></StackPanel></Border>
                            <Border Grid.Column="1" Style="{StaticResource PanelStyle}" Margin="0,0,0,8"><StackPanel><Grid Margin="0,0,0,8"><TextBlock Text="MEMORY · ADAPTIVE RANGE" FontSize="11" FontWeight="SemiBold"/><TextBlock Text="{Binding MemoryDetail}" HorizontalAlignment="Right" Foreground="#7357B8" FontFamily="Consolas" FontSize="10"/></Grid><controls:SmoothRealtimeChart Values="{Binding MemoryHistory}" Stroke="#7357B8" AutoRange="True" Unit="%" Height="170"/></StackPanel></Border>
                            <Border Grid.Row="1" Style="{StaticResource PanelStyle}" Margin="0,0,8,0"><StackPanel><Grid Margin="0,0,0,8"><TextBlock Text="DISK I/O · MB/s" FontSize="11" FontWeight="SemiBold"/><TextBlock Text="{Binding DiskValue}" HorizontalAlignment="Right" Foreground="#D47832" FontFamily="Consolas"/></Grid><controls:SmoothRealtimeChart Values="{Binding DiskHistory}" Stroke="#D47832" AutoRange="True" Unit="" Height="170"/></StackPanel></Border>
                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource PanelStyle}"><StackPanel><Grid Margin="0,0,0,8"><TextBlock Text="NETWORK · Mbps" FontSize="11" FontWeight="SemiBold"/><TextBlock Text="{Binding NetworkValue}" HorizontalAlignment="Right" Foreground="#249467" FontFamily="Consolas"/></Grid><controls:SmoothRealtimeChart Values="{Binding NetworkHistory}" Stroke="#249467" AutoRange="True" Unit="" Height="170"/></StackPanel></Border>
                        </Grid>
                        <Border Style="{StaticResource PanelStyle}" Margin="0,0,0,12"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="THERMALS" Foreground="{StaticResource Muted}" FontSize="10" FontWeight="SemiBold"/><TextBlock Text="{Binding TemperatureValue}" FontSize="16" FontWeight="SemiBold" Margin="0,5,0,0"/></StackPanel><TextBlock Grid.Column="1" Text="{Binding SensorDetail}" Foreground="{StaticResource Muted}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/><Button Grid.Column="2" Style="{StaticResource TextButton}" Content="센서 권한 재시작" Click="RestartElevated_Click" Margin="12,0,0,0"/></Grid></Border>
                        <ItemsControl ItemsSource="{Binding Diagnostics}"><ItemsControl.ItemTemplate><DataTemplate><Border BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="8,10"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="55"/><ColumnDefinition/></Grid.ColumnDefinitions><TextBlock Text="{Binding Severity}" FontFamily="Consolas" FontSize="10" Foreground="#1687C8"/><StackPanel Grid.Column="1"><TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12"/><TextBlock Text="{Binding Detail}" Foreground="{StaticResource Muted}" FontSize="10" Margin="0,3,0,0"/></StackPanel></Grid></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <Grid x:Name="HardwarePage" Visibility="Collapsed"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><StackPanel Margin="0,0,0,14"><TextBlock Text="HARDWARE INVENTORY" FontSize="20" FontWeight="SemiBold"/><TextBlock Text="CIM과 로컬 API에서 확인한 장치 구성" Foreground="{StaticResource Muted}" Margin="0,5,0,0"/></StackPanel><DataGrid Grid.Row="1" ItemsSource="{Binding HardwareItems}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"><DataGrid.Columns><DataGridTextColumn Header="분류" Binding="{Binding Category}" Width="150"><DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="TextTrimming" Value="CharacterEllipsis"/></Style></DataGridTextColumn.ElementStyle></DataGridTextColumn><DataGridTextColumn Header="장치" Binding="{Binding Name}" Width="2*"><DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="TextTrimming" Value="CharacterEllipsis"/></Style></DataGridTextColumn.ElementStyle></DataGridTextColumn><DataGridTextColumn Header="상세 정보" Binding="{Binding Value}" Width="3*"><DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="TextTrimming" Value="CharacterEllipsis"/></Style></DataGridTextColumn.ElementStyle></DataGridTextColumn></DataGrid.Columns></DataGrid></Grid>

                <ScrollViewer x:Name="BenchmarkPage" Visibility="Collapsed"><StackPanel><Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="270"/><ColumnDefinition/></Grid.ColumnDefinitions><Border Style="{StaticResource PanelStyle}" Margin="0,0,10,0"><StackPanel><TextBlock Text="SYSTEM SCORE" Foreground="{StaticResource Muted}" FontSize="10" FontWeight="SemiBold"/><TextBlock Text="{Binding OverallScoreText}" FontFamily="Consolas" FontSize="48" FontWeight="SemiBold" Margin="0,18,0,0"/><TextBlock Text="{Binding GradeText, StringFormat=GRADE {0}}" Foreground="#1687C8" FontFamily="Consolas" FontSize="15" Margin="0,4,0,20"/><ProgressBar Maximum="2000" Value="{Binding OverallScoreBar}"/><TextBlock Text="{Binding BenchmarkStatus}" Foreground="{StaticResource Muted}" FontSize="10" Margin="0,12,0,0"/></StackPanel></Border><Border Grid.Column="1" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Text="SCORE BREAKDOWN" FontSize="11" FontWeight="SemiBold"/><Grid Margin="0,22,0,7"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="CPU · SHA-256"/><TextBlock Grid.Column="1" Text="{Binding CpuBenchmarkText}" FontFamily="Consolas"/></Grid><ProgressBar Maximum="2000" Value="{Binding CpuScoreBar}" Foreground="#1687C8"/><Grid Margin="0,22,0,7"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="MEMORY · COPY"/><TextBlock Grid.Column="1" Text="{Binding MemoryBenchmarkText}" FontFamily="Consolas"/></Grid><ProgressBar Maximum="2000" Value="{Binding MemoryScoreBar}" Foreground="#7357B8"/><TextBlock Text="{Binding ScoringBasis}" Foreground="{StaticResource Muted}" FontSize="10" TextWrapping="Wrap" Margin="0,22,0,0"/></StackPanel></Border></Grid><Border Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Text="TEST CONTROL" FontSize="11" FontWeight="SemiBold"/><TextBlock Text="CPU는 1MiB SHA-256 처리량, 메모리는 64MiB 블록 복사 대역폭을 측정합니다. 워밍업 이후 일정 시간 반복하며 결과에 측정 환경과 산식을 함께 저장합니다." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,9,0,16"/><StackPanel Orientation="Horizontal"><Button Style="{StaticResource TextButton}" Content="벤치마크 시작" Click="RunBenchmark_Click" Margin="0,0,8,0"/><Button Style="{StaticResource TextButton}" Content="취소" Click="CancelBenchmark_Click" Background="#E4E7EB" Foreground="#303640"/></StackPanel></StackPanel></Border></StackPanel></ScrollViewer>

                <StackPanel x:Name="ReportPage" Visibility="Collapsed" MaxWidth="720" HorizontalAlignment="Left"><TextBlock Text="REPORT EXPORT" FontSize="20" FontWeight="SemiBold"/><TextBlock Text="하드웨어, 진단, 벤치마크 점수와 최근 60초 성능 지표를 JSON으로 내보냅니다." Foreground="{StaticResource Muted}" Margin="0,6,0,16"/><Border Style="{StaticResource PanelStyle}"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="STRUCTURED JSON" FontSize="11" FontWeight="SemiBold"/><TextBlock Text="원시 처리량, 정규화 점수, 산식, 환경 정보, 텔레메트리 배열 포함" Foreground="{StaticResource Muted}" FontSize="10" Margin="0,7,20,0"/></StackPanel><Button Grid.Column="1" Style="{StaticResource TextButton}" Content="내보내기" Click="Export_Click"/></Grid></Border></StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
